# RAP LIFE — serverless verse writer config (spec §6, RAPLIFE_ prefix).
# Copy to `.env.local` for `vercel dev`, or set these in the Vercel dashboard.
# The browser NEVER sees these — generation runs server-side only (spec §9).

# Required: Anthropic API key used by api/generate-verse.js
RAPLIFE_ANTHROPIC_KEY=sk-ant-...

# Optional: override the verse-writer model (defaults to claude-sonnet-4-6)
# RAPLIFE_MODEL=claude-sonnet-4-6

# Optional: family login gate (Aegis pattern, spec §11). Comma-separated codes.
# If set, /api/generate-verse requires a matching code; the handcrafted pack
# still plays without one. Leave unset to keep generation open (e.g. local dev).
# RAPLIFE_ACCESS_CODES=SKATER-ISLAND,BORN-BETWEEN

# ---- Local-only: voice pre-render (scripts/prerender-voices.mjs) ----
# ElevenLabs key for `npm run voices` (generates public/voices/*.mp3, committed).
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# OpenAI key, only for future character-art generation.
# OPENAI_API_KEY=
